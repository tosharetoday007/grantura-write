{
  "manifest_version": 2,
  "name": "Grantura Write",
  "version": "1.0.0",
  "description": "Privacy-first reference manager and AI manuscript generator for researchers.",
  "author": "Grantura",

  "icons": {
    "48":  "icons/icon-48.png",
    "96":  "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "https://api.crossref.org/*"
  ],

  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },

  "sidebar_action": {
    "default_title": "Grantura Write",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png"
    }
  },

  "browser_action": {
    "default_title": "Capture reference — Grantura Write",
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png"
    },
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["background/content.js"],
      "run_at": "document_idle"
    }
  ]
}
