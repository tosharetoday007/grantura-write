{
  "manifest_version": 2,
  "name": "Grantura Write",
  "version": "1.0.0",
  "description": "Privacy-first reference manager and AI manuscript generator for researchers. Capture references from any journal, build your library, and generate grounded manuscripts.",
  "author": "Grantura",
  "homepage_url": "https://github.com/YOUR_USERNAME/grantura-write",

  "icons": {
    "48":  "icons/icon-48.png",
    "96":  "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "activeTab",
    "storage",
    "sidebarAction",
    "https://api.crossref.org/*",
    "https://pubmed.ncbi.nlm.nih.gov/*",
    "https://scholar.google.com/*",
    "https://doi.org/*"
  ],

  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },

  "sidebar_action": {
    "default_title": "Grantura Write",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png"
    }
  },

  "browser_action": {
    "default_title": "Capture reference — Grantura Write",
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png"
    },
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.pubmed.ncbi.nlm.nih.gov/*",
        "*://*.scholar.google.com/*",
        "*://*.doi.org/*",
        "*://*.researchgate.net/*",
        "*://*.academia.edu/*",
        "*://*.sciencedirect.com/*",
        "*://*.springer.com/*",
        "*://*.wiley.com/*",
        "*://*.tandfonline.com/*",
        "*://*.nature.com/*",
        "*://*.bmj.com/*",
        "*://*.thelancet.com/*",
        "*://*.jamanetwork.com/*",
        "*://*.nejm.org/*",
        "*://*.arxiv.org/*",
        "*://*.biorxiv.org/*",
        "*://*.medrxiv.org/*",
        "*://*.cochranelibrary.com/*",
        "*://*.jstor.org/*",
        "*://*.acm.org/*",
        "*://*.ieee.org/*",
        "*://*/*"
      ],
      "js": ["background/content.js"],
      "run_at": "document_idle"
    }
  ]
}
